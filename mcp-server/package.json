{
  "name": "codex-video-vision",
  "version": "0.1.0",
  "description": "MCP server that gives Codex the ability to watch and understand videos; extracts frames via ffmpeg and processes audio via multiple backends",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codex-video-vision": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:mcp": "node scripts/smoke-mcp.js",
    "measure": "tsx scripts/measure-tokens.ts",
    "test:gemini": "tsx scripts/test-gemini-api.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "js-tiktoken": "^1.0.21",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@google/genai": "^1.50.1",
    "openai": "^4.80.0"
  },
  "keywords": [
    "codex",
    "codex-plugin",
    "mcp",
    "mcp-server",
    "video",
    "vision",
    "multimodal",
    "ffmpeg",
    "whisper",
    "gemini"
  ],
  "author": {
    "name": "Dan Gilles and contributors",
    "url": "https://github.com/EyrieCommander/codex-video-vision"
  },
  "contributors": [
    {
      "name": "Jordan Vasconcelos",
      "url": "https://github.com/jordanrendric"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/EyrieCommander/codex-video-vision",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EyrieCommander/codex-video-vision.git"
  },
  "bugs": {
    "url": "https://github.com/EyrieCommander/codex-video-vision/issues"
  }
}
